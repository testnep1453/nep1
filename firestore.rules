// ============================================
    // STUDENTS — Öğrenci verileri
    // ============================================
    match /students/{studentId} {
      // Oturum açmış herkes okuyabilir (giriş ID eşleşmesi için)
      allow read: if request.auth != null;
      // Oluşturma/silme sadece admin
      allow create, delete: if isAdmin();
      // Güncelleme: admin veya kendi profili (sadece izin verilen alanlar)
      allow update: if isAdmin() ||
      (
        isOwner(studentId) && 
        onlyUpdates(['nickname', 'email', 'avatar', 'lastSeen', 'xp', 'level', 'attendanceHistory', 'streak', 'badges'])
      );
    }
