rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USER MAPPINGS — Auth UID ↔ StudentId eşlemesi
    // ============================================
    match /userMappings/{uid} {
      // Sadece kendi mapping'ini okuyabilir
      allow read: if request.auth != null && request.auth.uid == uid;
      // Sadece kendi mapping'ini oluşturabilir/güncelleyebilir
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ============================================
    // STUDENTS — Öğrenci verileri
    // ============================================
    match /students/{studentId} {
      // Herkes okuyabilir (giriş ID eşleşmesi için)
      allow read: if true;
      // Oluşturma/silme sadece admin
      allow create, delete: if isAdmin();
      // Güncelleme: admin veya kendi profili
      allow update: if isAdmin() || isOwner(studentId);
    }

    // ============================================
    // MESSAGES — Admin duyuruları
    // ============================================    
    match /messages/{messageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // SETTINGS — Fragman, sistem ayarları
    // ============================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // ATTENDANCE — Yoklama kayıtları
    // ============================================
    match /attendance/{recordId} {
      allow read: if request.auth != null;
      // Oturum açmış herkes yoklama kaydı oluşturabilir
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // FEEDBACK — Geri bildirimler
    // ============================================
    match /feedback/{feedbackId} {
      allow read: if request.auth != null;
      // Oturum açmış herkes geri bildirim oluşturabilir
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // ARCHIVE — Video arşivi
    // ============================================
    match /archive/{videoId} {
      // Oturum açmış herkes okuyabilir
      allow read: if request.auth != null;
      // Yazma/silme sadece admin
      allow write: if isAdmin();
    }

    // ============================================
    // NOTIFICATIONS — Bildirimler (öğrenci bazlı)
    // ============================================
    match /notifications/{studentId}/items/{notifId} {
      // Sadece kendi bildirimlerini okuyabilir veya admin
      allow read: if isOwner(studentId) || isAdmin();
      // Admin bildirim gönderebilir
      allow create: if isAdmin();
      // Öğrenci okundu işaretleyebilir, admin her şeyi yapabilir
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // ADMIN — Admin ayarları (şifre hash vb.)
    // ============================================
    match /admin/{docId} {
      // Herkes okuyabilir (giriş doğrulama için)
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // LESSONS — Ders bilgileri
    // ============================================
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Admin kontrolü:
    // userMappings/{uid}.isAdmin == true ise admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/userMappings/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userMappings/$(request.auth.uid)).data.isAdmin == true;
    }

    // Sahiplik kontrolü:
    // userMappings/{uid}.studentId == istenen studentId ise sahip
    function isOwner(studentId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/userMappings/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userMappings/$(request.auth.uid)).data.studentId == studentId;
    }
  }
}
