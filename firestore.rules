rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USER MAPPINGS — Auth UID ↔ StudentId eşlemesi
    // ============================================
    match /userMappings/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ============================================
    // STUDENTS — Öğrenci verileri
    // ============================================
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      // Güncelleme kısıtlaması kaldırıldı, karakter vs. her alan güncellenebilir
      allow update: if isAdmin() || isOwner(studentId) || request.auth != null;
    }

    // ============================================
    // MESSAGES — Admin duyuruları
    // ============================================    
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // SETTINGS — Fragman, sistem ayarları
    // ============================================
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // ATTENDANCE — Yoklama kayıtları
    // ============================================
    match /attendance/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.studentId is string &&
        isOwner(request.resource.data.studentId);
      allow update, delete: if isAdmin();
    }

    // ============================================
    // FEEDBACK — Geri bildirimler (anonim)
    // ============================================
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // ARCHIVE — Video arşivi
    // ============================================
    match /archive/{videoId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // NOTIFICATIONS — Bildirimler (öğrenci bazlı)
    // ============================================
    match /notifications/{studentId}/items/{notifId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // ADMIN — Admin ayarları (şifre hash vb.)
    // ============================================
    match /admin/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // LESSONS — Ders bilgileri
    // ============================================
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // DEVICE LOGS — Cihaz takibi (SADECE ADMİN)
    // ============================================
    match /deviceLogs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // ADMIN LOGS — İşlem geçmişi (SADECE ADMİN)
    // ============================================
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; 
    }

    // ============================================
    // RATE LIMITS — Frekans sınırlandırma
    // ============================================
    match /rateLimits/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // LOGIN ALERTS — Şüpheli giriş uyarıları
    // ============================================
    match /loginAlerts/{alertId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // FROZEN ACCOUNTS — Dondurulmuş hesaplar
    // ============================================
    match /frozenAccounts/{studentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/userMappings/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userMappings/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(studentId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/userMappings/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userMappings/$(request.auth.uid)).data.studentId == studentId;
    }

    function onlyUpdates(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }
  }
}
